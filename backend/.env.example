# ===========================================================================
# MODÈLE de configuration — copier ce fichier en « .env » et remplir les valeurs
# ===========================================================================

DJANGO_SECRET_KEY=change-moi
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Vide = SQLite (dev). Renseigner l'URL Supabase en production.
DATABASE_URL=

# Chatbot RAG : fournisseur LLM (Groq par défaut, compatible OpenAI)
# Clé sur https://console.groq.com
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
